{
  "name": "wfhelper",
  "version": "1.1.2",
  "description": "A Warframe companion app - inventory viewer, foundry tracker, and more.",
  "main": ".electron-build/main.js",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm run build:main && vite build",
    "start": "pnpm run build && electron .",
    "dev": "pnpm run build:main && concurrently -k \"pnpm:dev:main\" \"pnpm:dev:preloads\" \"pnpm:dev:renderer\" \"pnpm:dev:electron\"",
    "verify:onnx-models": "node scripts/verify-onnx-models.mjs",
    "dist": "pnpm run verify:onnx-models && pnpm run build && electron-builder",
    "dist:win": "pnpm run verify:onnx-models && pnpm run build && electron-builder --win nsis",
    "check": "svelte-check --tsconfig tsconfig.json",
    "typecheck": "pnpm run typecheck:renderer && pnpm run typecheck:main && pnpm run typecheck:tests",
    "lint": "pnpm run lint:renderer && pnpm run lint:main && pnpm run lint:worker",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"renderer/*.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte,css}\" \"renderer/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist:win:publish": "pnpm run verify:onnx-models && pnpm run build && electron-builder --win nsis --publish always",
    "lint:renderer": "eslint src tests e2e playwright.config.ts --ext .ts,.svelte",
    "lint:main": "eslint main.ts preload.ts preload-overlay.ts preload-riven.ts preload-trade-notification.ts preload-arbi.ts config ipc services renderer --ext .js,.ts",
    "lint:worker": "eslint backend/worker/src backend/worker/test --ext .ts",
    "audit:prod": "pnpm audit --prod",
    "audit:all": "pnpm audit",
    "audit:deadcode": "knip && node scripts/check-prod-dead-exports.mjs",
    "audit:deadcode:exports": "knip --include exports,nsExports",
    "audit:deadcode:testonly": "node scripts/check-prod-dead-exports.mjs",
    "build:main": "tsc -p tsconfig.main.json && node scripts/bundle-preloads.js",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:preloads": "node scripts/bundle-preloads.js --watch",
    "dev:renderer": "vite build --watch",
    "typecheck:renderer": "tsc --noEmit",
    "dev:electron": "wait-on .electron-build/main.js renderer/dist/index.html && nodemon --watch .electron-build --watch renderer --ext js,json,html,css --exec electron .",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json",
    "test:main": "vitest run tests/main",
    "test:e2e": "pnpm run build && playwright test --config playwright.config.ts",
    "backend:dev": "npm --prefix backend/worker run dev",
    "backend:deploy": "npm --prefix backend/worker run deploy --",
    "backend:test": "npm --prefix backend/worker run test -- --run",
    "backend:typecheck": "npm --prefix backend/worker run typecheck",
    "backend:typegen": "npm --prefix backend/worker run cf-typegen",
    "validate:release-env": "node scripts/validate-release-env.mjs",
    "backend:prewarm:order-summaries": "powershell -ExecutionPolicy Bypass -File ./scripts/prewarm-order-summaries.ps1",
    "backend:prewarm:order-summaries:hotset": "powershell -ExecutionPolicy Bypass -File ./scripts/prewarm-order-summaries.ps1 -Source hotset",
    "icons:manifest": "pnpm run build:main && node scripts/icon-mirror/build-icon-manifest.mjs",
    "icons:download": "pnpm run icons:manifest && node scripts/icon-mirror/download-icon-mirror.mjs",
    "icons:deploy": "npm --prefix backend/worker exec -- wrangler pages deploy .icon-mirror/public --project-name wfhelper-icons --branch pre-production --commit-dirty=true",
    "icons:sync": "pnpm run icons:download && pnpm run icons:deploy",
    "rebuild": "electron-rebuild -f",
    "prepare": "husky"
  },
  "keywords": [
    "warframe",
    "companion",
    "inventory"
  ],
  "author": "WFHelper",
  "license": "MIT",
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^6.9.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.4",
    "svelte-eslint-parser": "^1.5.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@napi-rs/system-ocr": "^1.0.2",
    "@wfcd/items": "^1.1274.61",
    "chokidar": "^4.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "html-to-image": "^1.11.13",
    "koffi": "^2.15.1",
    "lzma": "^2.3.2",
    "ms": "2.1.3",
    "onnxruntime-node": "^1.24.3",
    "sharp": "^0.34.5",
    "warframe-public-export-plus": "^0.6.2",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.wfhelper.app",
    "productName": "WFHelper",
    "directories": {
      "output": "release"
    },
    "files": [
      ".electron-build/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/{test,tests,__tests__,example,examples,docs,doc}/**",
      "!node_modules/**/*.map",
      "!renderer/dist/**/*.map",
      "!renderer/dist/**/*.js.map",
      "!node_modules/**/*.md",
      "!node_modules/**/electron/**",
      "!node_modules/**/electron-builder/**",
      "!node_modules/**/app-builder-bin/**",
      "!node_modules/**/typescript/**",
      "!node_modules/**/vitest/**",
      "!node_modules/**/vite/**",
      "!node_modules/**/prettier/**",
      "!node_modules/**/eslint/**",
      "!node_modules/**/playwright*/**",
      "!node_modules/**/@playwright/**",
      "!node_modules/**/svelte-check/**"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "resources/riven-ocr",
        "to": "riven-ocr"
      },
      {
        "from": "resources/notification.wav",
        "to": "notification.wav"
      },
      {
        "from": "scripts/ocr-server.ps1",
        "to": "scripts/ocr-server.ps1"
      },
      {
        "from": "scripts/ocr.ps1",
        "to": "scripts/ocr.ps1"
      }
    ],
    "afterPack": "scripts/verify-packaged-runtime-assets.cjs",
    "win": {
      "icon": "assets/logo.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "installerIcon": "assets/logo.ico",
      "uninstallerIcon": "assets/logo.ico",
      "installerHeaderIcon": "assets/logo.ico",
      "include": "build/installer.nsh",
      "uninstallDisplayName": "WFHelper",
      "shortcutName": "WFHelper",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "WFHelper",
        "repo": "WFHelper",
        "releaseType": "release"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WFHelper/WFHelper.git"
  },
  "bugs": {
    "url": "https://github.com/WFHelper/WFHelper/issues"
  },
  "homepage": "https://github.com/WFHelper/WFHelper#readme"
}
