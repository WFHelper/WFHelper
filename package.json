{
  "name": "warframe-companion",
  "version": "1.0.0",
  "description": "A Warframe companion app - inventory viewer, foundry tracker, and more.",
  "main": ".electron-build/main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:main && vite build",
    "start": "npm run build && electron .",
    "dev": "npm run build:main && concurrently -k \"npm:dev:main\" \"npm:dev:preloads\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "verify:onnx-models": "node scripts/verify-onnx-models.mjs",
    "dist": "npm run verify:onnx-models && npm run build && electron-builder",
    "dist:win": "npm run verify:onnx-models && npm run build && electron-builder --win nsis",
    "check": "svelte-check --tsconfig tsconfig.json",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:main",
    "lint": "npm run lint:renderer && npm run lint:main",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:diagnostic:inventory": "vitest run tests/main/inventoryDiagnostic.test.ts src/lib/inventory.scale.test.ts",
    "test:diagnostic:wfm-backend": "vitest run src/lib/wfm/backendFallback.test.ts",
    "dist:win:publish": "npm run verify:onnx-models && npm run build && electron-builder --win nsis --publish always",
    "lint:renderer": "eslint src --ext .ts,.svelte",
    "lint:main": "eslint main.ts preload.ts preload-overlay.ts preload-riven.ts preload-trade-notification.ts config ipc services --ext .js,.ts",
    "audit:prod": "npm audit --omit=dev",
    "audit:all": "npm audit",
    "audit:deadcode": "knip",
    "audit:deadcode:exports": "knip --include exports,nsExports",
    "build:main": "tsc -p tsconfig.main.json && node scripts/bundle-preloads.js",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:preloads": "node scripts/bundle-preloads.js --watch",
    "dev:renderer": "vite build --watch",
    "typecheck:renderer": "tsc --noEmit",
    "dev:electron": "wait-on .electron-build/main.js renderer/dist/index.html && nodemon --watch .electron-build --watch renderer --ext js,json,html,css --exec electron .",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "test:main": "vitest run tests/main",
    "test:e2e": "npm run build && playwright test --config playwright.config.ts",
    "backend:dev": "npm --prefix backend-lite/worker run dev",
    "backend:deploy": "npm --prefix backend-lite/worker run deploy --",
    "backend:test": "npm --prefix backend-lite/worker run test -- --run",
    "backend:typegen": "npm --prefix backend-lite/worker run cf-typegen",
    "backend:prewarm:order-summaries": "powershell -ExecutionPolicy Bypass -File ./scripts/prewarm-order-summaries.ps1",
    "backend:prewarm:order-summaries:hotset": "powershell -ExecutionPolicy Bypass -File ./scripts/prewarm-order-summaries.ps1 -Source hotset",
    "backend:build-snapshot": "powershell -ExecutionPolicy Bypass -File ./scripts/build-snapshot.ps1",
    "icons:manifest": "npm run build:main && node scripts/icon-mirror/build-icon-manifest.mjs",
    "icons:download": "npm run icons:manifest && node scripts/icon-mirror/download-icon-mirror.mjs",
    "icons:deploy": "npm --prefix backend-lite/worker exec -- wrangler pages deploy .icon-mirror/public --project-name wfhelper-icons --branch pre-production --commit-dirty=true",
    "rebuild": "electron-rebuild -f -w uiohook-napi"
  },
  "keywords": [
    "warframe",
    "companion",
    "inventory"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/svelte": "^5.0.8",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "knip": "^6.9.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "svelte-eslint-parser": "^1.5.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "esbuild": "^0.25.11"
  },
  "dependencies": {
    "@napi-rs/system-ocr": "^1.0.2",
    "@sentry/browser": "^10.40.0",
    "@sentry/electron": "^7.9.0",
    "@types/ws": "^8.18.1",
    "@wfcd/items": "^1.1272.0",
    "chokidar": "^4.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "koffi": "^2.15.1",
    "onnxruntime-node": "^1.24.3",
    "uiohook-napi": "^1.5.4",
    "warframe-public-export-plus": "^0.5.101",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.warframe.companion",
    "productName": "WFHelper",
    "directories": {
      "output": "release"
    },
    "files": [
      ".electron-build/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/{test,tests,__tests__,example,examples,docs,doc}/**",
      "!node_modules/**/*.map",
      "!renderer/dist/**/*.map",
      "!renderer/dist/**/*.js.map",
      "!node_modules/**/*.md",
      "!node_modules/**/electron/**",
      "!node_modules/**/electron-builder/**",
      "!node_modules/**/app-builder-bin/**",
      "!node_modules/**/typescript/**",
      "!node_modules/**/vitest/**",
      "!node_modules/**/vite/**",
      "!node_modules/**/prettier/**",
      "!node_modules/**/eslint/**",
      "!node_modules/**/playwright*/**",
      "!node_modules/**/@playwright/**",
      "!node_modules/**/svelte-check/**"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "resources/riven-ocr",
        "to": "riven-ocr"
      },
      {
        "from": "scripts/ocr-server.ps1",
        "to": "scripts/ocr-server.ps1"
      },
      {
        "from": "scripts/ocr.ps1",
        "to": "scripts/ocr.ps1"
      }
    ],
    "afterPack": "scripts/verify-packaged-runtime-assets.cjs",
    "win": {
      "icon": "assets/logo.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "installerIcon": "assets/logo.ico",
      "uninstallerIcon": "assets/logo.ico",
      "installerHeaderIcon": "assets/logo.ico",
      "include": "build/installer.nsh",
      "uninstallDisplayName": "WFHelper",
      "shortcutName": "WFHelper",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MrZockertator",
        "repo": "warframe_companion",
        "releaseType": "release"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrZockertator/warframe_companion.git"
  },
  "bugs": {
    "url": "https://github.com/MrZockertator/warframe_companion/issues"
  },
  "homepage": "https://github.com/MrZockertator/warframe_companion#readme"
}
