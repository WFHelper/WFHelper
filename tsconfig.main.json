{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "ES2022.Error"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "electron"],
    "rootDir": ".",
    "outDir": ".electron-build",
    "noEmitOnError": true
  },
  "include": ["main.ts", "preload.ts", "preload-overlay.ts", "preload-riven.ts", "ipc/**/*.ts", "services/**/*.ts"]
}
