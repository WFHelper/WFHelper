# Gatekeeper before pushing to the remote.
# Mirrors CI's deterministic checks so failures surface here, not after a CI
# round-trip. `set -e` so any one blocks the push. Backend worker tests and the
# electron-builder packaging stay CI-only (flaky / heavy locally).
# Bypass with `git push --no-verify` if you really need to (don't make a habit).
set -e
pnpm typecheck
pnpm run check
pnpm lint
pnpm run audit:deadcode
pnpm test
