{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "checkJs": true,
    "allowJs": true,
    "types": ["svelte"]
  },
  "include": ["src/**/*"]
}
