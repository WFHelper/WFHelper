{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "main.ts",
    "preload.ts",
    "preload-overlay.ts",
    "preload-riven.ts",
    "preload-trade-notification.ts",
    "src/App.svelte",
    "src/modals/**/*.svelte",
    "src/views/**/*.svelte",
    "renderer/**/*.js",
    "backend/worker/src/index.ts",
    "backend/worker/test/**/*.ts",
    "tests/**/*.test.ts",
    "e2e/**/*.ts",
    "scripts/**/*.cjs",
    "scripts/**/*.js",
    "scripts/**/*.mjs"
  ],
  "project": ["**/*.{ts,js,mjs,cjs,svelte}"],
  "ignoreBinaries": ["powershell", "wrangler"],
  "ignoreDependencies": ["cloudflare", "esbuild", "ms", "svelte-eslint-parser", "tailwindcss"],
  "ignore": ["backend/worker/worker-configuration.d.ts", "scripts/dev/**"]
}
