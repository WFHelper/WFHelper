# Main process crash reporting
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_RELEASE=

# Renderer crash reporting (Vite envs must start with VITE_)
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_RELEASE=
VITE_APP_VERSION=
VITE_WFM_BACKEND_URL=
# Backend fallback behavior: always | high | never
VITE_WFM_BACKEND_DIRECT_FALLBACK=high

# Sourcemap upload for Vite build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Release publishing (GitHub Actions / local publish)
GH_TOKEN=

# Optional local override to disable auto-updater even in packaged app
WF_DISABLE_AUTO_UPDATE=0

