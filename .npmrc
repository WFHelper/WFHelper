# Supply-chain hardening.
#
# npm 11 has no native rolling "minimum release age", so we pin all dependency
# *resolution* to package versions published before a fixed cutoff date. A
# version published after this date will NOT be installed, which quarantines
# freshly-published (potentially compromised) releases until they have aged and
# any malicious publish has been caught/yanked.
#
# This does NOT affect `npm ci` — the committed package-lock.json is
# authoritative there and installs exact, integrity-checked versions. The
# cutoff only constrains `npm install <pkg>` / `npm update` / range re-resolves.
#
# Advance this date DELIBERATELY (e.g. monthly) once new versions have aged,
# then review the lockfile diff before committing.
before=2026-04-15

# Always verify registry integrity hashes; never fall back silently.
audit=true
fund=false
